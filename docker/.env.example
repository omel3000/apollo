# Postgres (używane przez docker-compose)
POSTGRES_USER=apollo
POSTGRES_PASSWORD=apollo123
POSTGRES_DB=apollo_test_db

# Opcjonalne — backend korzysta z tych zmiennych (docker-compose interpoluje DATABASE_URL z powyższych)
# Możesz też jawnie ustawić DATABASE_URL zamiast interpolacji
DATABASE_URL=postgresql://apollo:apollo123@postgres-db:5432/apollo_test_db

# JWT / auth
# ZASTĄP to silnym, losowym SECRET_KEY w środowisku produkcyjnym
SECRET_KEY=supersekretnykluczdojwt
ACCESS_TOKEN_EXPIRE_MINUTES=60

# === NOWE - Konfiguracja aplikacji ===
ENVIRONMENT=production # jeśli będzie = production - to /dosc i /redoc (Swagger UI) będzie niedostępne
LOG_LEVEL=warning # można dać =debug dla środowiska deweloperskiego
ALLOWED_ORIGINS=http://localhost,http://localhost:80 # Na produkcji ustawisz ALLOWED_ORIGINS=https://twoja-domena.pl

# Swagger UI / API Documentation
ENABLE_DOCS=true  # true = /docs i /redoc dostępne | false = wyłączone (bezpieczniejsze na produkcji)

# Startowe konto HR (tworzy się tylko, jeśli nie istnieje jeszcze żaden użytkownik z rolą hr)
INITIAL_ADMIN_ENABLED=true
INITIAL_ADMIN_EMAIL=hr@op.pl
INITIAL_ADMIN_PASSWORD=1234
INITIAL_ADMIN_FIRST_NAME=Admin
INITIAL_ADMIN_LAST_NAME=Administrator

# Backup PostgreSQL
BACKUP_CRON=0 3 * * *
BACKUP_RETENTION_DAYS=32
BACKUP_RUN_ON_STARTUP=true
POSTGRES_READY_TIMEOUT=60
TZ=Europe/Warsaw

# === Google Calendar Integration ===
# Dane z Google Cloud Console -> API & Services -> Credentials -> OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Redirect URI musi być zarejestrowany w Google Cloud Console!
# Lokalny dev:   http://localhost:8000/integrations/google/callback
# Produkcja:     https://twoja-domena.pl/integrations/google/callback
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/integrations/google/callback
GOOGLE_OAUTH_SCOPES=openid,email,profile,https://www.googleapis.com/auth/calendar.events,https://www.googleapis.com/auth/calendar.calendars,https://www.googleapis.com/auth/calendar.calendarlist.readonly
# Klucz szyfrowania refresh_tokenów — wygeneruj raz: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# MUSI być unikalny dla każdego środowiska! Nie commituj do repozytorium.
GOOGLE_TOKEN_ENCRYPTION_KEY=
# URL frontendu — po autoryzacji użytkownik wróci na tę stronę (schedule-view)
FRONTEND_URL=http://localhost
